@startuml
'https://plantuml.com/class-diagram

class Game{
    - int answer
    - Player player
    + void startGame()
    - void playGame()
}

class Player{
    - String name
    - int score
}

class ScoreBoard{
    - ArrayList<Player> players
    + void addPlayer(Player)
    + void printTopTen()
    + Player findPlayer(String name)
}

class IO{
    - Scanner scanner
    + void sendMessage(String msg)
    + String promptString(String msg)
    + int promptInt(String msg)
}

class GraphicIO{}

class Main{
    + void main()
}

class Scanner{}

enum TextColor{
    - String code
    String getCode()
}

enum BGColor{
    - String code
    String getCode()
}



IO *-- Scanner
Game *-- IO
Game *-- Player
Main *-- Game
IO <|-- GraphicIO
Game *-- ScoreBoard
ScoreBoard *-- Player
GraphicIO *-- TextColor
GraphicIO *-- BGColor


@enduml